# digicrm environment example
#
# Copy the values you need into digicrm/.env (which is git-ignored).
# Only the AI copilot variables are documented here; other runtime config
# (DATABASE_URL, JWT secret, etc.) lives in your real .env.

# ─── AI Copilot (Phase 1: text streaming) ────────────────────────────────────
# Provider fallback order: Kimi/Moonshot → OpenAI → Gemini → Grok/xAI.
# Leave all blank to get the graceful "AI provider not configured" response.

# PRIMARY — Kimi / Moonshot (OpenAI-compatible)
MOONSHOT_API_KEY=
# Optional overrides:
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# MOONSHOT_MODEL=kimi-k2-0905-preview

# MULTIMODAL / fallback — OpenAI (image + Whisper are Phase 2)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# FALLBACK — Google Gemini (thin REST adapter)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# FALLBACK — Grok / xAI (OpenAI-compatible)
XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-2-latest

# ─── AI Copilot (Phase 2a: CRM tool-calling) ─────────────────────────────────
# Master kill-switch for tool-calling. false → text-only Phase-1 behavior.
AI_TOOLS_ENABLED=true
# Max LLM⇄tool round-trips per request (runaway-loop guard).
AI_MAX_TOOL_ITERS=5
# Base URL the tool executor uses to re-call our OWN REST API, forwarding the
# caller's JWT (so tenant + RBAC are inherited). Point at this digicrm instance.
AI_INTERNAL_BASE_URL=http://127.0.0.1:8001
