# DigiCRM MCP Server — required environment variables
# Copy to .env and fill in your values before starting the MCP server.

# DigiCRM Django API
DIGICRM_BASE_URL=http://localhost:8000
DIGICRM_JWT_TOKEN=your-jwt-token-here
DIGICRM_TENANT_ID=your-tenant-uuid-here

# WhatsApp vendor credentials (from Laravel WhatsApp admin panel)
# These are injected as headers when digicrm calls the Laravel adapter.
WA_VENDOR_UID=your-vendor-uid
WA_API_TOKEN=your-api-token
WA_BASE_URL=https://whatsappapi.celiyo.com/api

# Optional
MCP_LOG_LEVEL=INFO
